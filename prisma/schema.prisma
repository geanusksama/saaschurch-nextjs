// ---------------------------------------------------------------------------
// LIVRO CAIXA — tabela principal de lançamentos financeiros
// Migrada do legado tblivrao com correção de tipos e relacionamentos.
// ---------------------------------------------------------------------------
model LivroCaixa {
  id             String   @id @default(uuid()) @db.Uuid

  // Igreja que registrou o lançamento (conta-caixa)
  churchId       String   @map("church_id") @db.Uuid

  // Data do lançamento — DATE nativo, sem texto, para evitar conversão em queries
  dataLancamento DateTime @map("data_lancamento") @db.Date

  // Referência/competência (ex: "Abril/2025")
  referencia     String?  @db.VarChar(100)

  // Valor: positivo = receita, negativo = despesa (ou use tipo para distinguir)
  valor          Decimal  @db.Decimal(15, 2)

  // Tipo: RECEITA | DESPESA | TRANSFERENCIA
  tipo           String   @db.VarChar(20)

  // Forma de pagamento (PIX, DINHEIRO, etc.)
  formaPg        String?  @map("forma_pg") @db.VarChar(50)

  // Plano de conta e categoria gerencial
  planoDeConta   String?  @map("plano_de_conta") @db.VarChar(100)
  categoria      String?  @db.VarChar(100)
  centroDeCusto  String?  @map("centro_de_custo") @db.VarChar(100)

  // Documento/numeração
  numLancamento  String?  @map("num_lancamento") @db.VarChar(50)
  numDoc         String?  @map("num_doc") @db.VarChar(50)
  tipoDocumento  String?  @map("tipo_documento") @db.VarChar(50)

  // Identificação do favorecido/pagador
  // tipo_pessoa: MEMBRO | NAO_MEMBRO | PJ | PF
  tipoPessoa     String?  @map("tipo_pessoa") @db.VarChar(20)
  favorecido     String?  @db.VarChar(255)

  // FK para membro (quando o favorecido é um membro cadastrado)
  memberId       String?  @map("member_id") @db.Uuid

  // ID externo para favorecidos não-membros (PF, PJ, fornecedor etc.)
  idFavorecidoExterno String? @map("id_favorecido_externo") @db.VarChar(100)

  // Operador que registrou
  operador       String?  @db.VarChar(255)
  operadorId     String?  @map("operador_id") @db.Uuid
  igrejaOperador String?  @map("igreja_operador") @db.VarChar(255)

  // Hierarquia (denormalizados para performance de relatórios)
  regional       String?  @db.VarChar(100)
  campo          String?  @db.VarChar(100)

  // Hash de integridade / auditoria
  hash           String?  @db.VarChar(255)

  // Extras
  obs            String?  @db.Text
  foto           String?  @db.VarChar(500)     // URL do comprovante
  identificador  String?  @db.VarChar(100)
  contaCaixa     String?  @map("conta_caixa") @db.VarChar(100)

  // Status
  situacao       Boolean  @default(true)
  deletadoPor    String?  @map("deletado_por") @db.VarChar(255)
  deletedAt      DateTime? @map("deleted_at")

  // ID do registro no sistema legado (para rastrear importação)
  legacyId       BigInt?  @map("legacy_id")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdBy      String?  @map("created_by") @db.Uuid
  updatedBy      String?  @map("updated_by") @db.Uuid

  // Relações
  church         Church   @relation(fields: [churchId], references: [id], onDelete: Cascade)
  member         Member?  @relation("LivroCaixaMember", fields: [memberId], references: [id])
  operadorUser   User?    @relation("LivroCaixaOperador", fields: [operadorId], references: [id])
  createdByUser  User?    @relation("LivroCaixaCreatedBy", fields: [createdBy], references: [id])
  updatedByUser  User?    @relation("LivroCaixaUpdatedBy", fields: [updatedBy], references: [id])

  // Índices para performance de relatórios (evita full-scan em queries por período/igreja)
  @@index([churchId, dataLancamento])
  @@index([memberId])
  @@index([tipo])
  @@index([planoDeConta])
  @@index([categoria])
  @@index([centroDeCusto])
  @@index([legacyId])
  @@index([campo])
  @@index([regional])
  @@map("livro_caixa")
}

