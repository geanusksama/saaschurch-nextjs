// ─────────────────────────────────────────────────────────────────────────────
// STRIPE — Integração de Pagamentos
// ─────────────────────────────────────────────────────────────────────────────

/// Configuração Stripe por campo (multi-tenant). Cada campo tem suas próprias chaves.
model StripeConfig {
  id               String  @id @default(uuid()) @db.Uuid
  campoId          String  @unique @map("campo_id") @db.Uuid
  publishableKey   String  @map("publishable_key") @db.VarChar(255)
  secretKeyEnc     String  @map("secret_key_enc") @db.Text        // criptografado AES-256
  webhookSecretEnc String? @map("webhook_secret_enc") @db.Text    // criptografado AES-256
  accountId        String? @map("account_id") @db.VarChar(100)    // Stripe Connect account ID
  ativo            Boolean @default(false)
  modoProd         Boolean @default(false) @map("modo_prod")      // false = test mode
  pixEnabled       Boolean @default(true)  @map("pix_enabled")
  cardEnabled      Boolean @default(true)  @map("card_enabled")
  currency         String  @default("brl") @db.VarChar(3)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at")

  campo         Campo              @relation("CampoStripeConfig", fields: [campoId], references: [id], onDelete: Cascade)
  payments      StripePayment[]
  subscriptions StripeSubscription[]

  @@map("stripe_configs")
}

/// Registro de cada pagamento processado via Stripe
model StripePayment {
  id                String   @id @default(uuid()) @db.Uuid
  configId          String   @map("config_id") @db.Uuid
  campoId           String   @map("campo_id") @db.Uuid
  churchId          String?  @map("church_id") @db.Uuid
  userId            String?  @map("user_id") @db.Uuid          // AppMembrosAuth.authUserId ou User.id
  memberId          String?  @map("member_id") @db.Uuid
  orderId           String?  @map("order_id") @db.Uuid         // EventOrder.id ou Order.id
  stripePaymentIntentId String? @map("stripe_payment_intent_id") @db.VarChar(100)
  stripeSessionId   String?  @map("stripe_session_id") @db.VarChar(100)
  stripeCustomerId  String?  @map("stripe_customer_id") @db.VarChar(100)
  stripeChargeId    String?  @map("stripe_charge_id") @db.VarChar(100)
  valor             Decimal  @db.Decimal(10, 2)
  valorRefunded     Decimal  @default(0) @map("valor_refunded") @db.Decimal(10, 2)
  moeda             String   @default("brl") @db.VarChar(3)
  metodo            String   @db.VarChar(30)    // pix | credit_card | debit_card | link | free
  tipo              String   @db.VarChar(30)    // ingresso | produto | dizimo | oferta | doacao | assinatura
  status            String   @default("pendente") @db.VarChar(30) // pendente | aprovado | falhou | reembolsado | parcialmente_reembolsado | expirado
  descricao         String?  @db.VarChar(500)
  pixQrCode         String?  @map("pix_qr_code") @db.Text
  pixExpira         DateTime? @map("pix_expira")
  receiptUrl        String?  @map("receipt_url") @db.VarChar(500)
  metadata          Json?    @db.JsonB
  paidAt            DateTime? @map("paid_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  config        StripeConfig     @relation(fields: [configId], references: [id])
  campo         Campo            @relation("CampoStripePayments", fields: [campoId], references: [id], onDelete: Cascade)
  church        Church?          @relation("ChurchStripePayments", fields: [churchId], references: [id])
  refunds       StripeRefund[]
  webhookLogs   StripeWebhookLog[]

  @@index([campoId])
  @@index([churchId])
  @@index([userId])
  @@index([stripePaymentIntentId])
  @@index([stripeSessionId])
  @@map("stripe_payments")
}

/// Assinaturas recorrentes Stripe
model StripeSubscription {
  id                   String   @id @default(uuid()) @db.Uuid
  configId             String   @map("config_id") @db.Uuid
  campoId              String   @map("campo_id") @db.Uuid
  churchId             String?  @map("church_id") @db.Uuid
  userId               String?  @map("user_id") @db.Uuid
  memberId             String?  @map("member_id") @db.Uuid
  stripeSubscriptionId String   @unique @map("stripe_subscription_id") @db.VarChar(100)
  stripeCustomerId     String?  @map("stripe_customer_id") @db.VarChar(100)
  stripePriceId        String?  @map("stripe_price_id") @db.VarChar(100)
  stripeProductId      String?  @map("stripe_product_id") @db.VarChar(100)
  tipo                 String?  @db.VarChar(30)
  valor                Decimal? @db.Decimal(10, 2)
  moeda                String   @default("brl") @db.VarChar(3)
  frequencia           String?  @db.VarChar(20)
  status               String   @default("ativa") @db.VarChar(20)
  proximaCobranca      DateTime? @map("proxima_cobranca")
  canceladaEm          DateTime? @map("cancelada_em")
  pausadaEm            DateTime? @map("pausada_em")
  descricao            String?  @db.VarChar(255)
  metadata             Json?    @db.JsonB

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  config  StripeConfig @relation(fields: [configId], references: [id])
  campo   Campo        @relation("CampoStripeSubscriptions", fields: [campoId], references: [id], onDelete: Cascade)
  church  Church?      @relation("ChurchStripeSubscriptions", fields: [churchId], references: [id])

  @@index([campoId])
  @@index([userId])
  @@index([stripeSubscriptionId])
  @@map("stripe_subscriptions")
}

/// Reembolsos processados via Stripe
model StripeRefund {
  id              String   @id @default(uuid()) @db.Uuid
  paymentId       String   @map("payment_id") @db.Uuid
  stripeRefundId  String?  @map("stripe_refund_id") @db.VarChar(100)
  valor           Decimal  @db.Decimal(10, 2)
  moeda           String   @default("brl") @db.VarChar(3)
  motivo          String?  @db.Text
  status          String   @default("solicitado") @db.VarChar(20) // solicitado | processado | rejeitado
  stripeStatus    String?  @map("stripe_status") @db.VarChar(20)
  solicitadoPor   String?  @map("solicitado_por") @db.Uuid
  aprovadoPor     String?  @map("aprovado_por") @db.Uuid
  motivoRejeicao  String?  @map("motivo_rejeicao") @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  payment StripePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@map("stripe_refunds")
}

/// Log de todos os webhooks recebidos do Stripe
model StripeWebhookLog {
  id           String   @id @default(uuid()) @db.Uuid
  campoId      String?  @map("campo_id") @db.Uuid
  paymentId    String?  @map("payment_id") @db.Uuid
  stripeEventId String  @unique @map("stripe_event_id") @db.VarChar(100)
  eventType    String   @map("event_type") @db.VarChar(100)
  payload      Json     @db.JsonB
  processado   Boolean  @default(false)
  erro         String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  payment StripePayment? @relation(fields: [paymentId], references: [id])

  @@index([campoId])
  @@index([stripeEventId])
  @@map("stripe_webhook_logs")
}
