// ──────────────────────────────────────────────────────────────────────────────
// SECRETARIA — Kanban / Pipeline / Matriz de Processos Eclesiásticos
// 3 níveis: KanPipeline (Secretaria) → KanStage (Batismo, Transferência, Consagração...)
//           → KanColumn (Pendente, Aprovado, Cancelado, Transferido...)
// Catálogo de serviços (KanService) + Matriz de regras (KanMatrixRule).
// Cards (KanCard) representam processos reais; cada movimento registra ocorrência
// no histórico do membro (MemberOccurrence).
// ──────────────────────────────────────────────────────────────────────────────

model KanPipeline {
  id       Int     @id @default(autoincrement())
  name     String  @db.VarChar(120)
  type     String? @db.VarChar(120)
  hash     String? @db.VarChar(60)
  campo    String? @db.VarChar(120)
  isActive Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stages KanStage[]

  @@map("kan_pipelines")
}

/// Catálogo de serviços eclesiásticos (sigla + descrição). Origem da matriz.
model KanService {
  id           Int     @id
  sigla        String  @db.VarChar(50)
  description  String  @db.VarChar(255)
  servico      String? @db.VarChar(120)
  serviceGroup String? @map("service_group") @db.VarChar(60)
  usesMatrix   Boolean @default(false) @map("uses_matrix")
  isActive     Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stages KanStage[]
  rules  KanMatrixRule[]
  cards  KanCard[]

  @@index([sigla])
  @@map("kan_services")
}

/// Stage (etapa do pipeline): Batismo, Transferência, Consagração, Requerimento...
/// Cada stage pertence a um pipeline e está vinculado a um serviço (matriz).
model KanStage {
  id          Int     @id @default(autoincrement())
  pipelineId  Int     @map("pipeline_id")
  serviceId   Int?    @map("service_id")
  name        String  @db.VarChar(120)
  description String? @db.VarChar(255)
  author      String? @db.VarChar(120)
  campo       String? @db.VarChar(120)
  hash        String? @db.VarChar(60)
  show        Boolean @default(true)
  isActive    Boolean @default(true) @map("is_active")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  pipeline KanPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  service  KanService? @relation(fields: [serviceId], references: [id])
  columns  KanColumn[]
  cards    KanCard[]
  matrixRules KanMatrixRule[]

  @@index([pipelineId])
  @@index([serviceId])
  @@map("kan_stages")
}

/// Coluna do kanban dentro do stage: Pendente, Aprovado, Cancelado, Transferido...
model KanColumn {
  id          Int     @id @default(autoincrement())
  stageId     Int     @map("stage_id")
  name        String  @db.VarChar(120)
  columnIndex Int     @map("column_index")
  color       String? @default("blue") @db.VarChar(20)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  stage KanStage  @relation(fields: [stageId], references: [id], onDelete: Cascade)
  cards KanCard[]

  @@unique([stageId, columnIndex])
  @@index([stageId])
  @@map("kan_columns")
}

/// Matriz de regras por serviço x coluna (define ações automáticas no movimento do card).
model KanMatrixRule {
  id          Int     @id @default(autoincrement())
  serviceId   Int     @map("service_id")
  columnIndex Int     @map("column_index")
  ageMin      Int     @default(0) @map("age_min")
  ageMax      Int     @default(0) @map("age_max")
  isActive    Boolean @default(true) @map("is_active")

  changeStatus        Boolean @default(false) @map("change_status")
  newStatus           String? @map("new_status") @db.VarChar(60)
  changeTitle         Boolean @default(false) @map("change_title")
  newTitle            String? @map("new_title") @db.VarChar(60)
  doesTransfer        Boolean @default(false) @map("does_transfer")
  insertOccurrence    Boolean @default(true) @map("insert_occurrence")
  occurrenceName      String? @map("occurrence_name") @db.VarChar(120)
  message             String? @db.VarChar(255)
  allowMessage        Boolean @default(false) @map("allow_message")
  allowDocModel       Boolean @default(false) @map("allow_doc_model")
  docModel            String? @map("doc_model") @db.VarChar(120)
  allowAttachments    Boolean @default(false) @map("allow_attachments")
  requireDocument     Boolean @default(false) @map("require_document")
  generatesCredential Boolean @default(false) @map("generates_credential")
  credentialKind      String? @map("credential_kind") @db.VarChar(60)
  credentialModel     String? @map("credential_model") @db.VarChar(60)
  credentialValidity  String? @map("credential_validity") @db.VarChar(60)
  servicoExtra        String? @map("servico_extra") @db.VarChar(60)
  description         String? @db.VarChar(255)
  stageId             Int?    @map("stage_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  service KanService @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  stage   KanStage?  @relation(fields: [stageId], references: [id])

  @@unique([serviceId, columnIndex])
  @@index([serviceId])
  @@index([stageId])
  @@map("kan_matrix_rules")
}

/// Card do kanban — instância real de um processo (Batismo de João, Transferência de Maria...).
model KanCard {
  id          String @id @default(uuid()) @db.Uuid
  protocol    String @unique @db.VarChar(60)
  stageId     Int    @map("stage_id")
  serviceId   Int    @map("service_id")
  columnId    Int?   @map("column_id")
  columnIndex Int    @default(1) @map("column_index")

  // Membro e igrejas principais
  churchId            String  @map("church_id") @db.Uuid             // Igreja origem
  memberId            String? @map("member_id") @db.Uuid
  destinationChurchId String? @map("destination_church_id") @db.Uuid  // Igreja destino (transferência)

  // Regionais (para relatórios e transferências)
  originRegionalId      String? @map("origin_regional_id") @db.Uuid
  destinationRegionalId String? @map("destination_regional_id") @db.Uuid

  // Igreja requerente e Igreja requerida (quem pediu / para quem foi pedido)
  requesterChurchId String? @map("requester_church_id") @db.Uuid
  requestedChurchId String? @map("requested_church_id") @db.Uuid
  requesterName     String? @map("requester_name") @db.VarChar(255)

  // Dados do membro no momento do processo
  candidateName String? @map("candidate_name") @db.VarChar(255)
  currentTitle  String? @map("current_title") @db.VarChar(60)
  intendedTitle String? @map("intended_title") @db.VarChar(60)

  // Status e controle de fluxo
  status      String  @default("pendente") @db.VarChar(60)
  statusLabel String? @map("status_label") @db.VarChar(120)

  // Textos do processo
  subject       String? @db.VarChar(255)                // assunto
  justification String? @db.Text                         // justificativa
  observations  String? @db.Text                         // obs
  description   String? @db.Text                         // descricao

  // Aprovação
  approvedBy String?   @map("approved_by") @db.Uuid
  approvedAt DateTime? @map("approved_at")

  metadata    Json?   @db.JsonB
  attachments Json?   @db.JsonB

  openedAt  DateTime  @default(now()) @map("opened_at")
  closedAt  DateTime? @map("closed_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at")

  stage             KanStage   @relation(fields: [stageId], references: [id])
  service           KanService @relation(fields: [serviceId], references: [id])
  column            KanColumn? @relation(fields: [columnId], references: [id])
  church            Church     @relation("KanCardChurch", fields: [churchId], references: [id], onDelete: Cascade)
  destinationChurch Church?    @relation("KanCardDestination", fields: [destinationChurchId], references: [id])
  requesterChurch   Church?    @relation("KanCardRequester", fields: [requesterChurchId], references: [id])
  requestedChurch   Church?    @relation("KanCardRequested", fields: [requestedChurchId], references: [id])
  member            Member?    @relation("KanCardMember", fields: [memberId], references: [id])
  originRegional    Regional?  @relation("KanCardOriginRegional", fields: [originRegionalId], references: [id])
  destinationRegional Regional? @relation("KanCardDestinationRegional", fields: [destinationRegionalId], references: [id])

  occurrences  MemberOccurrence[]
  eventHistory MemberEventHistory[] @relation("MemberEventHistoryCard")

  @@index([churchId])
  @@index([stageId, status])
  @@index([serviceId])
  @@index([openedAt])
  @@map("kan_cards")
}

/// Histórico/ocorrência do membro: gerado a cada movimento de card guiado pela matriz.
model MemberOccurrence {
  id       String  @id @default(uuid()) @db.Uuid
  memberId String? @map("member_id") @db.Uuid
  churchId String  @map("church_id") @db.Uuid
  cardId   String? @map("card_id") @db.Uuid

  name         String  @db.VarChar(160)
  message      String? @db.VarChar(255)
  serviceSigla String? @map("service_sigla") @db.VarChar(50)
  serviceGroup String? @map("service_group") @db.VarChar(60)
  action       String? @db.VarChar(120)
  columnIndex  Int?    @map("column_index")
  memberCity   String? @map("member_city") @db.VarChar(100)
  memberState  String? @map("member_state") @db.VarChar(50)
  memberCountry String? @map("member_country") @db.VarChar(100)

  metadata Json? @db.JsonB

  occurredAt DateTime @default(now()) @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")
  createdBy  String?  @map("created_by") @db.Uuid

  member Member?  @relation("MemberOccurrenceMember", fields: [memberId], references: [id])
  church Church   @relation("MemberOccurrenceChurch", fields: [churchId], references: [id], onDelete: Cascade)
  card   KanCard? @relation(fields: [cardId], references: [id])

  @@index([memberId])
  @@index([churchId, occurredAt])
  @@map("member_occurrences")
}

/// Histórico de títulos eclesiásticos do membro: registra cada troca de título.
model MemberTitleHistory {
  id            String   @id @default(uuid()) @db.Uuid
  memberId      String   @map("member_id") @db.Uuid
  churchId      String   @map("church_id") @db.Uuid
  cardId        String?  @map("card_id") @db.Uuid
  previousTitle String?  @map("previous_title") @db.VarChar(120)
  newTitle      String   @map("new_title") @db.VarChar(120)
  source        String?  @db.VarChar(60) // "MATRIZ", "MANUAL", etc.
  serviceGroup  String?  @map("service_group") @db.VarChar(60)
  serviceName   String?  @map("service_name") @db.VarChar(255)
  memberCity    String?  @map("member_city") @db.VarChar(100)
  memberState   String?  @map("member_state") @db.VarChar(50)
  memberCountry String?  @map("member_country") @db.VarChar(100)
  notes         String?  @db.Text
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  member Member @relation("MemberTitleHistoryMember", fields: [memberId], references: [id], onDelete: Cascade)
  church Church @relation("MemberTitleHistoryChurch", fields: [churchId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([churchId, createdAt])
  @@map("member_title_history")
}

/// Histórico de eventos do membro: gerado a cada ação da matriz de decisão.
model MemberEventHistory {
  id           String   @id @default(uuid()) @db.Uuid
  memberId     String?  @map("member_id") @db.Uuid
  cardId       String?  @map("card_id") @db.Uuid
  churchId     String   @map("church_id") @db.Uuid
  serviceGroup  String?  @map("service_group") @db.VarChar(60)
  serviceName   String?  @map("service_name") @db.VarChar(255)
  columnIndex   Int?     @map("column_index")
  action        String?  @db.VarChar(120)
  memberCity    String?  @map("member_city") @db.VarChar(100)
  memberState   String?  @map("member_state") @db.VarChar(50)
  memberCountry String?  @map("member_country") @db.VarChar(100)
  notes         String?  @db.Text
  metadata      Json?    @db.JsonB
  createdBy     String?  @map("created_by") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at")

  member Member?  @relation("MemberEventHistoryMember", fields: [memberId], references: [id], onDelete: SetNull)
  card   KanCard? @relation("MemberEventHistoryCard",   fields: [cardId],   references: [id], onDelete: SetNull)
  church Church   @relation("MemberEventHistoryChurch", fields: [churchId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([churchId, createdAt])
  @@map("member_event_history")
}

model InboxMessage {
  id        String   @id @default(uuid()) @db.Uuid
  subject   String   @db.VarChar(255)
  body      String   @db.Text
  senderId  String   @map("sender_id") @db.Uuid
  campoId   String?  @map("campo_id") @db.Uuid
  threadId  String?  @map("thread_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  sender      User              @relation("SentInboxMessages", fields: [senderId], references: [id])
  campo       Campo?            @relation(fields: [campoId], references: [id])
  recipients  InboxRecipient[]
  attachments InboxAttachment[]

  @@index([threadId])
  @@map("inbox_messages")
}

model InboxRecipient {
  id            String    @id @default(uuid()) @db.Uuid
  messageId     String    @map("message_id") @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  recipientType String    @default("TO") @map("recipient_type") @db.VarChar(10)
  isRead        Boolean   @default(false) @map("is_read")
  isStarred     Boolean   @default(false) @map("is_starred")
  isDeleted     Boolean   @default(false) @map("is_deleted")
  isImportant   Boolean   @default(false) @map("is_important")
  readAt        DateTime? @map("read_at")
  deletedAt     DateTime? @map("deleted_at")

  message InboxMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User         @relation("ReceivedInboxMessages", fields: [userId], references: [id])

  @@map("inbox_recipients")
}

model InboxAttachment {
  id        String @id @default(uuid()) @db.Uuid
  messageId String @map("message_id") @db.Uuid
  name      String @db.VarChar(255)
  url       String @db.Text
  size      Int
  type      String @db.VarChar(100)

  message InboxMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("inbox_attachments")
}

/// Programação anual do campo (agenda de eventos do ano)
model TbEvento {
  id             String   @id @default(uuid()) @db.Uuid
  evento         String
  datareal       DateTime @db.Date
  dia            Int      @db.SmallInt
  mes            String
  ano            Int      @db.SmallInt
  horario        String?
  local          String?
  obs            String?
  foto           String?
  preco          Decimal  @default(0) @db.Decimal
  pago           Boolean  @default(false)
  tipo           String   @default("gratuito")
  keypg          String?
  ministerio     String?
  mostrar        Boolean  @default(true)
  reservar       Boolean  @default(false)
  campo          String?
  regional       String?
  igreja         String?
  campoId        String   @map("campo_id") @db.Uuid
  headquartersId String?  @map("headquarters_id") @db.Uuid
  churchId       String?  @map("church_id") @db.Uuid
  audienceScope  String   @default("headquarters") @map("audience_scope")
  diaSemana      String?  @map("dia_semana")
  departamento   String?
  iconName       String?  @map("icon_name") @db.VarChar(50)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([campoId])
  @@index([ano, mes])
  @@map("tbeventos")
}
