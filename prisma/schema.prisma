generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Campo {
  id                 String  @id @default(uuid()) @db.Uuid
  name               String  @db.VarChar(255)
  code               String  @unique @db.VarChar(50)
  description        String? @db.Text
  logoUrl            String? @map("logo_url") @db.VarChar(500)
  country            String? @default("Brasil") @db.VarChar(100)
  accessPasswordHash String? @map("access_password_hash") @db.VarChar(255)
  domain             String? @db.VarChar(255)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  regionais          Regional[]
  users              User[]                     @relation("CampoUsers")
  inboxMessages      InboxMessage[]
  legacyRegionals    LegacyRegional[]           @relation("LegacyRegionalField")
  legacyHeadquarters LegacyChurchHeadquarters[] @relation("LegacyHeadquartersField")
  legacyChurches     LegacyChurch[]             @relation("LegacyChurchField")
  members            Member[]                   @relation("CampoMembers")

  @@map("campos")
}

model Regional {
  id            String  @id @default(uuid()) @db.Uuid
  campoId       String  @map("campo_id") @db.Uuid
  name          String  @db.VarChar(255)
  code          String  @db.VarChar(50)
  description   String? @db.Text
  coordinatorId String? @map("coordinator_id") @db.Uuid
  state         String? @db.VarChar(100)
  city          String? @db.VarChar(100)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  campo       Campo    @relation(fields: [campoId], references: [id], onDelete: Cascade)
  coordinator User?    @relation("RegionalCoordinator", fields: [coordinatorId], references: [id])
  churches    Church[]
  users       User[]   @relation("RegionalUsers")
  members     Member[]
  kanCardsOrigin      KanCard[] @relation("KanCardOriginRegional")
  kanCardsDestination KanCard[] @relation("KanCardDestinationRegional")

  @@unique([campoId, code])
  @@map("regionais")
}

model Church {
  id             String  @id @default(uuid()) @db.Uuid
  regionalId     String  @map("regional_id") @db.Uuid
  name           String  @db.VarChar(255)
  code           String  @db.VarChar(50)
  legalName      String? @map("legal_name") @db.VarChar(255)
  cnpj           String? @unique @db.VarChar(18)
  leadPastorId   String? @map("lead_pastor_id") @db.Uuid
  parentChurchId String? @map("parent_church_id") @db.Uuid
  headquartersId String? @map("headquarters_id") @db.Uuid

  currentLeaderName     String?   @map("current_leader_name") @db.VarChar(255)
  currentLeaderRole     String?   @map("current_leader_role") @db.VarChar(255)
  currentLeaderRoleDate DateTime? @map("current_leader_role_date") @db.Date
  leaderRoll            String?   @map("leader_roll") @db.VarChar(50)
  entryDate             DateTime? @map("entry_date") @db.Date
  exitDate              DateTime? @map("exit_date") @db.Date
  hash                  String?   @db.VarChar(100)
  plateName             String?   @map("plate_name") @db.VarChar(255)
  documentType          String?   @map("document_type") @db.VarChar(30)
  documentNumber        String?   @map("document_number") @db.VarChar(50)
  hasOwnTemple          Boolean   @default(false) @map("has_own_temple")
  notes                 String?   @db.Text

  email    String? @db.VarChar(255)
  phone    String? @db.VarChar(20)
  whatsapp String? @db.VarChar(20)
  website  String? @db.VarChar(255)

  addressStreet       String?  @map("address_street") @db.VarChar(255)
  addressNumber       String?  @map("address_number") @db.VarChar(20)
  addressComplement   String?  @map("address_complement") @db.VarChar(100)
  addressNeighborhood String?  @map("address_neighborhood") @db.VarChar(100)
  addressCity         String?  @map("address_city") @db.VarChar(100)
  addressState        String?  @map("address_state") @db.VarChar(50)
  addressZipcode      String?  @map("address_zipcode") @db.VarChar(10)
  addressCountry      String?  @default("Brasil") @map("address_country") @db.VarChar(100)
  latitude            Decimal? @db.Decimal(10, 8)
  longitude           Decimal? @db.Decimal(11, 8)

  logoUrl        String? @map("logo_url") @db.VarChar(500)
  primaryColor   String? @default("#8b5cf6") @map("primary_color") @db.VarChar(7)
  secondaryColor String? @default("#3b82f6") @map("secondary_color") @db.VarChar(7)

  timezone String? @default("America/Sao_Paulo") @db.VarChar(50)
  currency String? @default("BRL") @db.VarChar(3)
  language String? @default("pt-BR") @db.VarChar(5)

  status    String?   @default("active") @db.VarChar(20)
  foundedAt DateTime? @map("founded_at") @db.Date

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  regional      Regional                  @relation(fields: [regionalId], references: [id], onDelete: Cascade)
  leadPastor    User?                     @relation("ChurchLeadPastor", fields: [leadPastorId], references: [id])
  parentChurch  Church?                   @relation("ChurchParent", fields: [parentChurchId], references: [id])
  childChurches Church[]                  @relation("ChurchParent")
  headquarters  LegacyChurchHeadquarters? @relation("ChurchHeadquarters", fields: [headquartersId], references: [id])

  users                  User[]                  @relation("ChurchUsers")
  roles                  Role[]
  members                Member[]
  contacts               ChurchContact[]
  functionHistory        ChurchFunctionHistory[]
  leaderHistory          ChurchLeaderHistory[]
  rentRecords            ChurchRentRecord[]
  financialAccounts      FinancialAccount[]
  financialCategories    FinancialCategory[]
  transactions           Transaction[]
  offerings              Offering[]
  baptisms               Baptism[]
  events                 Event[]
  leads                  Lead[]
  discipleshipTracks     DiscipleshipTrack[]
  ministries             Ministry[]
  cellGroups             CellGroup[]
  communicationCampaigns CommunicationCampaign[]
  communicationTemplates CommunicationTemplate[]
  messages               Message[]
  pages                  Page[]
  blogPosts              BlogPost[]
  sermons                Sermon[]
  memberTags             MemberTag[]
  auditLogs              AuditLog[]
  settings               Setting[]
  webhooks               Webhook[]

  kanCards              KanCard[]          @relation("KanCardChurch")
  kanCardsAsDestination KanCard[]          @relation("KanCardDestination")
  kanCardsAsRequester   KanCard[]          @relation("KanCardRequester")
  kanCardsAsRequested   KanCard[]          @relation("KanCardRequested")
  memberOccurrences     MemberOccurrence[] @relation("MemberOccurrenceChurch")
  eventHistory          MemberEventHistory[] @relation("MemberEventHistoryChurch")
  titleHistory          MemberTitleHistory[] @relation("MemberTitleHistoryChurch")

  livroCaixa            LivroCaixa[]

  @@unique([regionalId, code])
  @@index([headquartersId])
  @@map("churches")
}

model ChurchContact {
  id        String  @id @default(uuid()) @db.Uuid
  churchId  String  @map("church_id") @db.Uuid
  type      String  @db.VarChar(50)
  name      String? @db.VarChar(150)
  value     String  @db.VarChar(255)
  notes     String? @db.Text
  isPrimary Boolean @default(false) @map("is_primary")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId])
  @@map("church_contacts")
}

model ChurchFunctionCatalog {
  id                  String    @id @default(uuid()) @db.Uuid
  createdAt           DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  abbreviation        String?   @map("abbreviation") @db.VarChar(255)
  name                String?   @map("name") @db.VarChar(255)
  isActive            Boolean?  @map("is_active")
  number              String?   @map("number") @db.VarChar(255)
  prerequisiteLevel   BigInt?   @map("prerequisite_level")
  minimumAge          BigInt?   @map("minimum_age")
  maximumAge          BigInt?   @map("maximum_age")
  displayOrder        BigInt?   @map("display_order")
  requiresMinimumDate Boolean?  @map("requires_minimum_date")
  isLeaderRole        Boolean?  @map("is_leader_role")
  isBoardRole         Boolean?  @map("is_board_role")
  onlyMinister        Boolean?  @map("only_minister")
  allowMen            Boolean?  @map("allow_men")
  allowWomen          Boolean?  @map("allow_women")
  profiles            String?   @map("profiles") @db.VarChar(255)
  fieldName           String?   @map("field_name") @db.VarChar(255)

  churchFunctionHistory ChurchFunctionHistory[]
  churchLeaderHistory   ChurchLeaderHistory[]

  @@map("church_function_catalog")
}

model ChurchFunctionHistory {
  id         String    @id @default(uuid()) @db.Uuid
  churchId   String    @map("church_id") @db.Uuid
  memberId   String    @map("member_id") @db.Uuid
  functionId String    @map("function_id") @db.Uuid
  department String?   @db.VarChar(150)
  startDate  DateTime  @map("start_date") @db.Date
  endDate    DateTime? @map("end_date") @db.Date
  notes      String?   @db.Text
  isActive   Boolean   @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  church   Church                @relation(fields: [churchId], references: [id], onDelete: Cascade)
  member   Member                @relation("ChurchFunctionMember", fields: [memberId], references: [id], onDelete: Cascade)
  function ChurchFunctionCatalog @relation(fields: [functionId], references: [id], onDelete: Restrict)

  @@index([churchId, functionId])
  @@index([memberId])
  @@map("church_function_history")
}

model ChurchRentRecord {
  id                  String    @id @default(uuid()) @db.Uuid
  churchId            String    @map("church_id") @db.Uuid
  city                String    @db.VarChar(100)
  address             String    @db.VarChar(255)
  amount              Decimal   @db.Decimal(12, 2)
  ownerName           String?   @map("owner_name") @db.VarChar(150)
  ownerDocumentType   String?   @map("owner_document_type") @db.VarChar(10)
  ownerDocumentNumber String?   @map("owner_document_number") @db.VarChar(20)
  paidAt              DateTime  @map("paid_at") @db.Date
  receiptUrl          String?   @map("receipt_url") @db.VarChar(500)
  notes               String?   @db.Text
  isActive            Boolean   @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  church Church @relation(fields: [churchId], references: [id], onDelete: Cascade)

  @@index([churchId, paidAt])
  @@map("church_rent_records")
}

model ChurchLeaderHistory {
  id                     String    @id @default(uuid()) @db.Uuid
  churchId               String    @map("church_id") @db.Uuid
  previousLeaderMemberId String?   @map("previous_leader_member_id") @db.Uuid
  newLeaderMemberId      String?   @map("new_leader_member_id") @db.Uuid
  functionId             String?   @map("function_id") @db.Uuid
  indicatedBy            String    @map("indicated_by") @db.VarChar(255)
  changeReason           String    @map("change_reason") @db.Text
  entryDate              DateTime  @map("entry_date") @db.Date
  previousExitDate       DateTime? @map("previous_exit_date") @db.Date
  currentCash            Decimal?  @map("current_cash") @db.Decimal(12, 2)
  averageIncome          Decimal?  @map("average_income") @db.Decimal(12, 2)
  averageExpense         Decimal?  @map("average_expense") @db.Decimal(12, 2)
  maxIncome              Decimal?  @map("max_income") @db.Decimal(12, 2)
  totalMembers           Int?      @map("total_members")
  totalWorkers           Int?      @map("total_workers")
  notes                  String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  church               Church                 @relation(fields: [churchId], references: [id], onDelete: Cascade)
  previousLeaderMember Member?                @relation("ChurchLeaderHistoryPreviousMember", fields: [previousLeaderMemberId], references: [id])
  newLeaderMember      Member?                @relation("ChurchLeaderHistoryNewMember", fields: [newLeaderMemberId], references: [id])
  function             ChurchFunctionCatalog? @relation(fields: [functionId], references: [id], onDelete: Restrict)

  @@index([churchId, entryDate])
  @@map("church_leader_history")
}

model User {
  id         String  @id @default(uuid()) @db.Uuid
  churchId   String? @map("church_id") @db.Uuid
  campoId    String? @map("campo_id") @db.Uuid
  regionalId String? @map("regional_id") @db.Uuid
  email      String  @unique @db.VarChar(255)

  fullName  String  @map("full_name") @db.VarChar(255)
  systemEmail String? @unique @map("system_email") @db.VarChar(255)
  avatarUrl String? @map("avatar_url") @db.VarChar(500)
  phone     String? @db.VarChar(20)

  // profileType: master | admin | campo | church
  profileType String @default("church") @map("profile_type") @db.VarChar(20)

  roleId      String? @map("role_id") @db.Uuid
  isAdmin     Boolean @default(false) @map("is_admin")
  isActive    Boolean @default(true) @map("is_active")
  permissions Json?   @db.JsonB

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  church   Church?   @relation("ChurchUsers", fields: [churchId], references: [id], onDelete: Cascade)
  campo    Campo?    @relation("CampoUsers", fields: [campoId], references: [id])
  regional Regional? @relation("RegionalUsers", fields: [regionalId], references: [id])
  role     Role?     @relation(fields: [roleId], references: [id])

  churchesAsLeadPastor   Church[]   @relation("ChurchLeadPastor")
  regionaisAsCoordinator Regional[] @relation("RegionalCoordinator")

  members       Member[] @relation("MemberUser")
  memberCreated Member[] @relation("MemberCreatedBy")
  memberUpdated Member[] @relation("MemberUpdatedBy")

  eventRegistrationsCheckedIn EventRegistration[] @relation("EventRegistrationCheckinBy")
  eventAttendanceCreated      EventAttendance[]   @relation("EventAttendanceCreatedBy")
  eventsOrganized             Event[]             @relation("EventOrganizer")

  leadActivitiesCreated LeadActivity[] @relation("LeadActivityCreatedBy")
  leadsAssigned         Lead[]         @relation("LeadAssignedTo")
  leadsCreated          Lead[]         @relation("LeadCreatedBy")
  leadsUpdated          Lead[]         @relation("LeadUpdatedBy")

  transactionsCreated Transaction[] @relation("TransactionCreatedBy")
  transactionsUpdated Transaction[] @relation("TransactionUpdatedBy")

  livroCaixaOperado   LivroCaixa[] @relation("LivroCaixaOperador")
  livroCaixaCreated   LivroCaixa[] @relation("LivroCaixaCreatedBy")
  livroCaixaUpdated   LivroCaixa[] @relation("LivroCaixaUpdatedBy")

  communicationCampaignsCreated CommunicationCampaign[] @relation("CampaignCreatedBy")

  pagesCreated      Page[]     @relation("PageCreatedBy")
  pagesUpdated      Page[]     @relation("PageUpdatedBy")
  blogPostsAuthored BlogPost[] @relation("BlogPostAuthor")
  blogPostsCreated  BlogPost[] @relation("BlogPostCreatedBy")
  blogPostsUpdated  BlogPost[] @relation("BlogPostUpdatedBy")

  notifications   Notification[]
  auditLogs       AuditLog[]
  settingsUpdated Setting[]      @relation("SettingUpdatedBy")

  sentInboxMessages     InboxMessage[]   @relation("SentInboxMessages")
  receivedInboxMessages InboxRecipient[] @relation("ReceivedInboxMessages")

  @@map("users")
}

model Role {
  id          String  @id @default(uuid()) @db.Uuid
  churchId    String? @map("church_id") @db.Uuid
  name        String  @db.VarChar(100)
  description String? @db.Text
  color       String? @default("#8b5cf6") @db.VarChar(7)
  permissions Json?   @db.JsonB
  isSystem    Boolean @default(false) @map("is_system")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  church Church? @relation(fields: [churchId], references: [id], onDelete: Cascade)
  users  User[]

  @@unique([churchId, name])
  @@map("roles")
}

model EcclesiasticalTitle {
  id                       String    @id @default(uuid()) @db.Uuid
  name                     String    @unique @db.VarChar(120)
  abbreviation             String?   @map("abbreviation") @db.VarChar(30)
  level                    Int       @default(0)
  grouping                 String?   @map("grouping") @db.VarChar(120)
  prerequisiteLevel        Int?      @map("prerequisite_level")
  minimumAge               Int?      @map("minimum_age")
  maximumAge               Int?      @map("maximum_age")
  prerequisiteOccurrence   String?   @map("prerequisite_occurrence") @db.Text
  isActive                 Boolean   @default(true) @map("is_active")
  isFixed                  Boolean   @default(false) @map("is_fixed")
  isEcclesiasticalMinister Boolean   @default(false) @map("is_ecclesiastical_minister")
  allowMen                 Boolean   @default(true) @map("allow_men")
  allowWomen               Boolean   @default(true) @map("allow_women")
  profile                  String?   @db.VarChar(120)
  displayOrder             Int       @default(0) @map("display_order")
  consecrationTypeKey      String?   @map("consecration_type_key") @db.VarChar(50)
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")
  deletedAt                DateTime? @map("deleted_at")

  members Member[]

  @@map("ecclesiastical_titles")
}

model Member {
  id                    String  @id @default(uuid()) @db.Uuid
  churchId              String  @map("church_id") @db.Uuid
  regionalId            String? @map("regional_id") @db.Uuid
  campoId               String? @map("campo_id") @db.Uuid
  userId                String? @map("user_id") @db.Uuid
  ecclesiasticalTitleId String? @map("ecclesiastical_title_id") @db.Uuid
  memberType            String? @default("MEMBRO") @map("member_type") @db.VarChar(20)
  rol                   Int?    @default(autoincrement())

  fullName      String  @map("full_name") @db.VarChar(255)
  preferredName String? @map("preferred_name") @db.VarChar(100)
  fantasyName   String? @map("fantasy_name") @db.VarChar(255)
  photoUrl      String? @map("photo_url") @db.VarChar(500)
  coverPhotoUrl String? @map("cover_photo_url") @db.Text

  cpf           String?   @unique @db.VarChar(14)
  cnpj          String?   @db.VarChar(18)
  rg            String?   @db.VarChar(20)
  birthDate     DateTime? @map("birth_date") @db.Date
  gender        String?   @db.VarChar(20)
  maritalStatus String?   @map("marital_status") @db.VarChar(20)

  email  String? @db.VarChar(255)
  phone  String? @db.VarChar(20)
  mobile String? @db.VarChar(20)

  addressStreet       String? @map("address_street") @db.VarChar(255)
  addressNumber       String? @map("address_number") @db.VarChar(20)
  addressComplement   String? @map("address_complement") @db.VarChar(100)
  addressNeighborhood String? @map("address_neighborhood") @db.VarChar(100)
  addressCity         String? @map("address_city") @db.VarChar(100)
  addressState        String? @map("address_state") @db.VarChar(50)
  addressZipcode      String? @map("address_zipcode") @db.VarChar(10)

  membershipStatus    String?   @default("AGUARDANDO ATIVACAO") @map("membership_status") @db.VarChar(30)
  membershipDate      DateTime? @map("membership_date") @db.Date
  ecclesiasticalTitle String?   @default("CONGREGADO") @map("ecclesiastical_title") @db.VarChar(120)
  baptismStatus       String?   @map("baptism_status") @db.VarChar(20)
  baptismDate         DateTime? @map("baptism_date") @db.Date

  fatherName        String? @map("father_name") @db.VarChar(255)
  motherName        String? @map("mother_name") @db.VarChar(255)
  spouseId          String? @map("spouse_id") @db.Uuid
  spouseName        String? @map("spouse_name") @db.VarChar(255)
  naturalityCity    String? @map("naturality_city") @db.VarChar(100)
  naturalityState   String? @map("naturality_state") @db.VarChar(2)
  nationality       String? @db.VarChar(100)
  voterRegistration String? @map("voter_registration") @db.VarChar(20)
  voterZone         String? @map("voter_zone") @db.VarChar(10)
  voterSection      String? @map("voter_section") @db.VarChar(10)

  occupation String? @db.VarChar(255)
  company    String? @db.VarChar(255)

  notes                 String? @db.Text
  emergencyContactName  String? @map("emergency_contact_name") @db.VarChar(255)
  emergencyContactPhone String? @map("emergency_contact_phone") @db.VarChar(20)

  searchVector Unsupported("tsvector")? @map("search_vector")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  deletedAt DateTime? @map("deleted_at")

  church                 Church               @relation(fields: [churchId], references: [id], onDelete: Cascade)
  regional               Regional?            @relation(fields: [regionalId], references: [id])
  campo                  Campo?               @relation("CampoMembers", fields: [campoId], references: [id])
  user                   User?                @relation("MemberUser", fields: [userId], references: [id])
  ecclesiasticalTitleRef EcclesiasticalTitle? @relation(fields: [ecclesiasticalTitleId], references: [id])
  spouse                 Member?              @relation("MemberSpouse", fields: [spouseId], references: [id])
  spouseOf               Member[]             @relation("MemberSpouse")

  createdByUser User? @relation("MemberCreatedBy", fields: [createdBy], references: [id])
  updatedByUser User? @relation("MemberUpdatedBy", fields: [updatedBy], references: [id])

  baptisms                   Baptism[]
  baptismsMinistered         Baptism[]                  @relation("BaptismMinister")
  familyRelationships        MemberFamilyRelationship[] @relation("MemberFamilyMember")
  relatedFamilyRelationships MemberFamilyRelationship[] @relation("MemberFamilyRelated")

  memberTagAssignments MemberTagAssignment[]
  offerings            Offering[]
  donorTransactions    Transaction[]         @relation("TransactionDonor")
  livroCaixaEntries    LivroCaixa[]          @relation("LivroCaixaMember")
  eventAttendance      EventAttendance[]
  eventRegistrations   EventRegistration[]

  discipleshipEnrollments       DiscipleshipEnrollment[]
  discipleshipMentorEnrollments DiscipleshipEnrollment[] @relation("DiscipleshipMentor")

  ministryMemberships  MinistryMember[]
  cellGroupMemberships CellGroupMember[]

  cellGroupsLed         CellGroup[]             @relation("CellGroupLeader")
  cellGroupsHosted      CellGroup[]             @relation("CellGroupHost")
  ministriesLed         Ministry[]              @relation("MinistryLeader")
  churchFunctions       ChurchFunctionHistory[] @relation("ChurchFunctionMember")
  previousLeaderHistory ChurchLeaderHistory[]   @relation("ChurchLeaderHistoryPreviousMember")
  newLeaderHistory      ChurchLeaderHistory[]   @relation("ChurchLeaderHistoryNewMember")

  sermonsPreached Sermon[]
  leadsConverted  Lead[]   @relation("LeadMember")

  kanCards    KanCard[]          @relation("KanCardMember")
  occurrences MemberOccurrence[] @relation("MemberOccurrenceMember")
  eventHistory MemberEventHistory[] @relation("MemberEventHistoryMember")
  titleHistory MemberTitleHistory[] @relation("MemberTitleHistoryMember")

  @@index([churchId])
  @@index([campoId])
  @@index([ecclesiasticalTitleId])
  @@index([memberType])
  @@index([regionalId])
  @@index([membershipStatus])
  @@map("members")
}

model MemberFamilyRelationship {
  id               String   @id @default(uuid()) @db.Uuid
  memberId         String   @map("member_id") @db.Uuid
  relatedMemberId  String   @map("related_member_id") @db.Uuid
  relationshipType String   @map("relationship_type") @db.VarChar(30)
  createdAt        DateTime @default(now()) @map("created_at")

  member        Member @relation("MemberFamilyMember", fields: [memberId], references: [id], onDelete: Cascade)
  relatedMember Member @relation("MemberFamilyRelated", fields: [relatedMemberId], references: [id], onDelete: Cascade)

  @@unique([memberId, relatedMemberId, relationshipType])
  @@map("member_family_relationships")
}

model Baptism {
  id                String   @id @default(uuid()) @db.Uuid
  churchId          String   @map("church_id") @db.Uuid
  memberId          String   @map("member_id") @db.Uuid
  baptismDate       DateTime @map("baptism_date") @db.Date
  location          String?  @db.VarChar(255)
  ministerId        String?  @map("minister_id") @db.Uuid
